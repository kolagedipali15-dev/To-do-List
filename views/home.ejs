            text-decoration: none;
            border-radius: 5px;
            margin-top: 20px;
        }
        .btn:hover{
            background-color: #e4e9ef; 
            color:rgb(9, 93, 99);
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Welcome to Task Project</h1>
        <a href="/task" class="btn">Go to Task</a>
    </div>
</body>

</html>
